# Mensagia API token
# Get your token from https://app.mensagia.com/settings/api
MENSAGIA_API_TOKEN=your_api_token_here

# Language (optional): es | ca | gl | eu | en
# If not set, the app will ask on startup (console) or detect the system language (GUI)
MENSAGIA_LANGUAGE=

# Attachment base URL (optional)
# If contact fields contain relative paths instead of full URLs, this base URL is prepended.
# If not set and needed, the console will ask interactively.
MENSAGIA_ATTACHMENT_BASE_URL=
